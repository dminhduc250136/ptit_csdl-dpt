# Supabase PostgreSQL connection
# Lấy từ: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Lưu ý: nếu dùng connection pooler thì port 6543, direct connection port 5432.
# Cho batch job (insert hàng nghìn row) nên dùng direct (5432) để tránh limit pooler.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Cloudinary (chỉ cần nếu sau muốn upload thêm hoặc lấy signed URL)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
